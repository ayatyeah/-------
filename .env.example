# Пример настроек окружения для ТОО «СХМ Агро».
#
# Скопируйте этот файл в .env и поменяйте значения:
#   cp .env.example .env
#
# Файл .env в git не попадает (см. .gitignore) — там пароли.
# Переменные читает сам Node (флаг --env-file-if-exists), без библиотек.

# Порт API-сервера. Клиент (vite) проксирует /api сюда.
PORT=3001

# Пароль входа в админку.
# Задан здесь — перекрывает значение в базе. ОБЯЗАТЕЛЬНО смените перед публикацией.
ADMIN_PASSWORD=admin

# Кому разрешены запросы к API.
# В разработке — адрес vite. На проде укажите домен сайта, например https://shmagro.kz
# Звёздочка (*) открывает API всем — так только для локальной разработки.
CORS_ORIGIN=http://localhost:5173

# Путь к файлу базы SQLite. По умолчанию — data/shmagro.db рядом с проектом.
# DB_PATH=./data/shmagro.db
