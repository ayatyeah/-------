# Пример настроек окружения для ТОО «СХМ Агро».
#
# Скопируйте этот файл в .env и поменяйте значения:
#   cp .env.example .env
#
# Файл .env в git не попадает (см. .gitignore) — там пароли.
# Переменные читает сам Node (флаг --env-file-if-exists), без библиотек.

# Порт API-сервера. Клиент (vite) проксирует /api сюда.
PORT=3001

# Пароль входа в админку.
# Задан здесь — перекрывает значение в базе. ОБЯЗАТЕЛЬНО смените перед публикацией:
# на публичном адресе со стандартным «admin» в панель войдёт кто угодно.
ADMIN_PASSWORD=admin

# Секрет для подписи сессий админки. Любая длинная случайная строка.
# Сгенерировать: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Если не задан — подпись работает на разовом ключе и сессии слетают при каждом
# перезапуске (после деплоя вход заново). Задайте, чтобы сессии жили.
JWT_SECRET=

# Сколько часов живёт сессия админки после входа. По умолчанию 12.
# SESSION_TTL_HOURS=12

# Кому разрешены запросы к API.
# В разработке — адрес vite. На проде укажите домен сайта, например https://shmagro.kz
# Звёздочка (*) открывает API всем — так только для локальной разработки.
CORS_ORIGIN=http://localhost:5173

# Где лежат данные сайта. Базы данных сейчас нет — всё в одном JSON-файле
# внутри проекта. По умолчанию: data/store.json
# STORE_PATH=./data/store.json

# --- ИИ ---------------------------------------------------------------------
# Работают анализатор лидов в админке и чат-ассистент на главной.
# Порядок такой: OpenAI -> Gemini -> правила.
# Без ключей сайт полностью работает на правилах — ничего не сломается.
# Библиотек ставить не нужно: запросы идут обычным fetch.

# Порядок провайдеров. Первый, у кого есть ключ и кто ответил, тот и отвечает.
# Поменять местами можно прямо здесь, без правки кода:
#   AI_ORDER=gemini,openai
# AI_ORDER=openai,gemini

# OpenAI — основной.
# Внимание: gpt-5-mini — reasoning-модель, часть токенов уходит на
# внутренние рассуждения. При маленьком лимите ответ приходит ПУСТОЙ,
# поэтому в коде лимиты заведомо щедрые. Отвечает медленнее Gemini.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini

# Gemini — резерв, включается когда OpenAI не ответил.
# Ключей можно указать до трёх: если один упёрся в лимит (429), сервер сам
# возьмёт следующий.
GEMINI_API_KEY=
# GEMINI_API_KEY_2=
# GEMINI_API_KEY_3=
GEMINI_MODEL=gemini-2.5-flash
