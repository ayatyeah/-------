# Шифрование для боевого домена.
#
# Caddy сам получает сертификат Let's Encrypt и продлевает его — ничего
# настраивать и продлевать руками не нужно. Работает при двух условиях:
# домен из DOMAIN указывает A-записью на этот сервер, а порты 80 и 443
# открыты в файрволе.
#
# Используется только с профилем tls:
#     docker compose --profile tls up -d

{
	email {$EMAIL}
}

{$DOMAIN} {
	# Сайт живёт в соседнем контейнере, внутри общей сети compose.
	reverse_proxy web:3001

	# Сжатие: у каталога и списка моделей заметный JSON.
	encode zstd gzip

	# Заголовки безопасности сервер ставит сам (CSP, HSTS, X-Frame-Options).
	# Здесь их не дублируем, чтобы не разъехались две правды.

	log {
		output file /data/access.log {
			roll_size 10mb
			roll_keep 5
		}
	}
}
