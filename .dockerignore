# Что НЕ должно попасть в образ.
#
# Главное здесь — секреты. Файл .env и .mcp.json содержат боевые ключи;
# попав в слой образа, они останутся в нём навсегда, даже если удалить их
# следующей командой. Переменные передаются через docker compose, а не
# файлом внутри образа.

# --- секреты ---------------------------------------------------------------
.env
.env.*
!.env.example
.mcp.json

# --- зависимости и сборка (ставятся и собираются внутри образа) -------------
node_modules
dist
dist-ssr

# --- данные и бэкапы (живут на томе, а не в образе) -------------------------
data
backups

# --- история и служебное ----------------------------------------------------
.git
.gitignore
.gitattributes
.github
.vscode
.idea
.claude
.playwright-mcp

# --- рабочий мусор ----------------------------------------------------------
# Только в корне! Шаблон без «/» вырезал бы и public/assets/logo.png —
# логотип пропал бы с сайта и из вкладки браузера.
/*.log
/*.png
/*.tmp.mjs
Dockerfile
docker-compose.yml
DEPLOY*.md
README*.md

# Исходный офлайн-макет, из которого брался контент, — в образе не нужен.
# index.html оставляем: это точка входа сборки Vite.
/*.html
!/index.html
