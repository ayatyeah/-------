# --- Секреты ---------------------------------------------------------------
# .env содержит пароль админки — в репозиторий он попасть не должен.
# Образец без секретов лежит в .env.example и коммитится.
.env
.env.*
!.env.example

# --- Зависимости и сборка --------------------------------------------------
node_modules
dist
dist-ssr

# --- База данных -----------------------------------------------------------
# Файл базы создаётся командой npm run init-db, в git не хранится.
data/
*.db
*.db-journal
*.db-wal
*.db-shm

# --- Логи ------------------------------------------------------------------
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- Редакторы и ОС --------------------------------------------------------
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
Thumbs.db
desktop.ini
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# --- Временное -------------------------------------------------------------
*.local
.cache
.temp
coverage
